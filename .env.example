# 네이버 쇼핑 검색 API 키 (선택)
# https://developers.naver.com/apps 에서 애플리케이션 등록 후 발급
# 설정하지 않으면 data/mock-products.json 데모 데이터로 동작합니다.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 서버 포트 (기본 3000)
PORT=3000

# 세션 서명 및 소스 비밀정보 암호화에 사용되는 키 (운영 환경 필수)
# 길고 무작위한 값으로 설정하세요. 예: openssl rand -hex 32
APP_SECRET=

# 운영 환경에서는 production 으로 설정 (HTTPS secure 쿠키 활성화)
NODE_ENV=

# 계정 데이터(users.json) 저장 폴더. Railway 등에서는 볼륨 마운트 경로 지정 (예: /data)
# 미지정 시 저장소의 data/ 폴더 사용
DATA_DIR=
